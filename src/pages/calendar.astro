---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Calendar — Bird Friendly Kitchener-Waterloo">
  <Header slot="header" currentPath="/calendar" />

  <section class="page-header">
    <div class="container">
      <h1>Events Calendar</h1>
    </div>
  </section>

  <div class="calendar-container">
    <p class="calendar-intro">
      Stay up to date with upcoming Bird Friendly Kitchener-Waterloo events,
      volunteer opportunities, and community activities.
    </p>
    <div class="calendar-embed">
      <iframe
        src="https://calendar.google.com/calendar/embed?src=birdfriendlykitchener%40gmail.com&ctz=America%2FToronto"
        title="Bird Friendly Kitchener-Waterloo Events Calendar"
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
